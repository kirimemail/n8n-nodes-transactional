{
	"name": "@kirimemail/n8n-nodes-transactional",
	"version": "0.1.0",
	"description": "Kirim.Email transactional email nodes for n8n - send emails and receive webhooks",
	"license": "MIT",
	"homepage": "https://smtp-app.kirim.email",
	"keywords": [
		"n8n-community-node-package",
		"kirimemail",
		"transactional",
		"email",
		"smtp",
		"webhook"
	],
	"author": {
		"name": "Gamal Abdul Nasser",
		"email": "gamalan@kirim.email"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kirimemail/n8n-nodes-transactional.git"
	},
	"bugs": {
		"url": "https://github.com/kirimemail/n8n-nodes-transactional/issues"
	},
	"scripts": {
		"build": "n8n-node build && npm run copy-assets",
		"copy-assets": "cp -r assets dist/nodes/KirimEmailTransactional/ && cp -r assets dist/nodes/KirimEmailTrigger/ && cp -r assets dist/credentials/",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build && npm run copy-assets"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/KirimEmailApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/KirimEmailTransactional/KirimEmailTransactional.node.js",
			"dist/nodes/KirimEmailTrigger/KirimEmailTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"form-data": "^4.0.0"
	}
}
